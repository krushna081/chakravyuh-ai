{
  "name": "chakravyuh-ai-monorepo",
  "version": "0.1.0-alpha",
  "description": "Multi-Agent AI Operating System — Unify, Orchestrate, Autonomous",
  "private": true,
  "license": "Apache-2.0",
  "author": "krushna081",
  "homepage": "https://github.com/krushna081/chakravyuh-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/krushna081/chakravyuh-ai.git"
  },
  "bugs": {
    "url": "https://github.com/krushna081/chakravyuh-ai/issues"
  },
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x"
  },
  "type": "module",
  "workspaces": [
    "backend",
    "agents/*",
    "mcp/servers/*",
    "memory/drivers/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node backend/src/index.ts",
    "clean": "rimraf dist coverage",
    "lint": "eslint 'backend/src/**/*.ts' 'agents/**/*.ts' 'mcp/**/*.ts' 'memory/**/*.ts'",
    "lint:fix": "eslint --fix 'backend/src/**/*.ts' 'agents/**/*.ts' 'mcp/**/*.ts' 'memory/**/*.ts'",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config tests/vitest.config.ts",
    "docs": "typedoc --out docs/api backend/src/index.ts"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9",
    "eslint": "^9.0.0",
    "typedoc": "^0.26.0",
    "rimraf": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "keywords": [
    "ai", "multi-agent", "orchestrator", "mcp",
    "model-context-protocol", "llm", "openai",
    "anthropic", "gemini", "deepseek", "ollama",
    "autonomous", "agents"
  ]
}
