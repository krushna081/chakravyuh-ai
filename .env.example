# ═══ Chakravyuh AI Configuration ═══
# Copy this to .env and customize

# ── Router Mode ──────────────────────────────────────
# local  = always Ollama (local or cloud, default)
# hybrid = Ollama for small, cloud providers for complex
# cloud  = always cloud providers (OpenAI, Anthropic, etc.)
CHAKRAVYUH_ROUTER_MODE=local

# ── Ollama ───────────────────────────────────────────
# For local Ollama:
#   OLLAMA_HOST=http://127.0.0.1:11434
# For Ollama Cloud (no GPU needed):
#   OLLAMA_HOST=https://ollama.com
#   OLLAMA_API_KEY=your_api_key_here
OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_API_KEY=
CHAKRAVYUH_OLLAMA_DEFAULT_MODEL=llama3.1:8b

# ── Cloud Providers (optional) ───────────────────────
# Only needed if router_mode is hybrid or cloud
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# GROQ_API_KEY=...
# OPENROUTER_API_KEY=sk-...

# ── Memory ──────────────────────────────────────────
CHAKRAVYUH_MEMORY_BACKEND=sqlite
# CHAKRAVYUH_MEMORY_BACKEND=chroma
CHAKRAVYUH_SQLITE_PATH=data/memory.db
CHAKRAVYUH_CHROMA_PATH=data/chromadb

# ── API Server ──────────────────────────────────────
CHAKRAVYUH_API_HOST=127.0.0.1
CHAKRAVYUH_API_PORT=3001

# ── Docker ──────────────────────────────────────────
# PUID=1000
# PGID=1000

# ── Logging ─────────────────────────────────────────
CHAKRAVYUH_LOG_LEVEL=INFO
