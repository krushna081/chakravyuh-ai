# ═══════════════════════════════════════════════════════════════
# ⚔  CHAKRAVYUH AI  —  Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this to .env and edit as needed:
#   cp .env.example .env
#
# Default: local-first (Ollama). Add API keys for cloud providers.

# ── Server ──────────────────────────────────────────────────────
CHAKRAVYUH_HOST=127.0.0.1
CHAKRAVYUH_PORT=3001
LOG_LEVEL=info

# ── Default LLM Provider ────────────────────────────────────────
# Options: ollama (default), openai, anthropic, google, deepseek
DEFAULT_PROVIDER=ollama
# If using a cloud provider, set your API key:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...

# ── Ollama Configuration ────────────────────────────────────────
# Point to local or remote Ollama instance.
# In Docker: http://ollama:11434
# Native:    http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Default model for chat/agents
OLLAMA_CHAT_MODEL=llama3.1:8b
# Model for embeddings (memory / RAG)
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5
# Auto-pull models if missing (true / false)
OLLAMA_AUTO_PULL=true

# ── Model Router ─────────────────────────────────────────────────
# Intelligently route tasks based on size / sensitivity.
# "local": always use Ollama (default)
# "hybrid": small tasks → Ollama, complex → cloud (requires API key)
# "cloud": always use cloud provider
MODEL_ROUTER_MODE=local

# ── Security ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# ── Memory & Vector Store ───────────────────────────────────────
# Options: sqlite (default), chromadb, filesystem
MEMORY_BACKEND=sqlite
# ChromaDB connection (in Docker: http://chromadb:8000)
CHROMA_DB_URL=http://127.0.0.1:8100

# ── MCP Servers ─────────────────────────────────────────────────
# Enable or disable built-in MCP servers
MCP_ENABLED=true
MCP_FILESYSTEM_ENABLED=true
MCP_BROWSER_ENABLED=true
MCP_WEB_FETCH_ENABLED=true

# ── Docker (used by docker-compose.yml) ─────────────────────────
# PUID/PGID for file ownership in bind mounts
PUID=1000
PGID=1000
# GPU support: uncomment one of:
# COMPOSE_FILE=docker-compose.yml:docker/gpu.nvidia.yml
# COMPOSE_FILE=docker-compose.yml:docker/gpu.amd.yml
