# =============================================================================
# Chakravyuh AI — Environment Configuration
# =============================================================================
# At least one provider API key is required for cloud-based operation.
# For fully offline use, configure Ollama only.
# =============================================================================



# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Gemini ────────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ── DeepSeek ─────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── Grok (xAI) ───────────────────────────────────────────────────────────────
GROK_API_KEY=

# ── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama (Local) ───────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Memory Backends ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite://memory/chakravyuh.db
VECTOR_DB_URL=
VECTOR_DB_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────────────────────────
# Encryption key for sensitive data at rest (32-byte hex)
ENCRYPTION_KEY=
# JWT secret for API authentication
JWT_SECRET=
# Session timeout in minutes
SESSION_TIMEOUT=60

# ── Rate Limiting ────────────────────────────────────────────────────────────
GLOBAL_RATE_LIMIT_RPM=100
GLOBAL_RATE_LIMIT_TPM=500000

# ── Tracing & Monitoring ─────────────────────────────────────────────────────
OTEL_SERVICE_NAME=chakravyuh-ai
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_BROWSER_AUTOMATION=false
ENABLE_WEB_SERVER=true
ENABLE_MCP_AUTO_START=true
